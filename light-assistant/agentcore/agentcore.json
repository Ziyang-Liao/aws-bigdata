{
  "name": "light",
  "version": 1,
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "light"
  },
  "agents": [
    {
      "type": "AgentCoreRuntime",
      "name": "light",
      "build": "Container",
      "entrypoint": "main.ts",
      "codeLocation": "app/light-ts/",
      "runtimeVersion": "NODE_22",
      "networkMode": "PUBLIC",
      "modelProvider": "Bedrock",
      "protocol": "HTTP"
    }
  ],
  "memories": [],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [
    {
      "name": "device-control",
      "description": "Skill: Device Control — power, brightness, color control and status query for smart lights",
      "authorizerType": "NONE",
      "exceptionLevel": "DEBUG",
      "targets": [
        {
          "name": "device-control-lambda",
          "targetType": "lambdaFunctionArn",
          "lambdaFunctionArn": {
            "lambdaArn": "arn:aws:lambda:us-east-1:774868049561:function:light-device-control",
            "toolSchemaFile": "skills/device-control/schema.json"
          }
        }
      ]
    },
    {
      "name": "scene-orchestration",
      "description": "Skill: Scene Orchestration — preset themes and dynamic AI-generated lighting scenes",
      "authorizerType": "NONE",
      "exceptionLevel": "DEBUG",
      "targets": [
        {
          "name": "scene-orchestration-lambda",
          "targetType": "lambdaFunctionArn",
          "lambdaFunctionArn": {
            "lambdaArn": "arn:aws:lambda:us-east-1:774868049561:function:light-scene-orchestration",
            "toolSchemaFile": "skills/scene-orchestration/schema.json"
          }
        }
      ]
    },
    {
      "name": "device-discovery",
      "description": "Skill: Device Discovery — discover available devices and resolve nicknames to device IDs",
      "authorizerType": "NONE",
      "exceptionLevel": "DEBUG",
      "targets": [
        {
          "name": "device-discovery-lambda",
          "targetType": "lambdaFunctionArn",
          "lambdaFunctionArn": {
            "lambdaArn": "arn:aws:lambda:us-east-1:774868049561:function:light-device-discovery",
            "toolSchemaFile": "skills/device-discovery/schema.json"
          }
        }
      ]
    }
  ],
  "policyEngines": []
}
